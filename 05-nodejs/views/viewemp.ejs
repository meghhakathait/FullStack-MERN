<%- include('comman/header',{title:'Employee List'})%>

    <div class="container">
        <div class="row">
            <div class="col-sm-8 offset-sm-2">
                <h1 class="text-center">Employee List</h1>
                <table class="table table-primary" id="emplist">
                    <thead>
                        <tr>
                            <th>Employee ID</th>
                            <th>Employee Name</th>
                            <th>Employee Department</th>
                            <th>Employee Photo</th>
                        </tr>
                    </thead>
                    <tbody>

                        <% if(locals.employee){%>
                            <% employee.forEach(emp=>{%>
                                <tr>
                                    <td>
                                        <%emp.id%>
                                    </td>
                                    <td>
                                        <%emp.name%>
                                    </td>
                                    <td>
                                        <%emp.dept%>
                                    </td>
                                    <td><img src="../static/Employee_photos/<%=emp.photo%>" width="100" alt=""></td>
                                </tr>
                                <%})%>
                                    <%}%>
                                    <!-- agr iski value set hui to niche vala chelga agr nhi hui to ye chelega -->

                    </tbody>
                </table>
                <% if(locals.message){%>
                    <div class="alert alert-danger mt-2">
                        <%message%>
                    </div>
                    <%}%>

            </div>
        </div>
    </div>





    <%- include('comman/footer')%>